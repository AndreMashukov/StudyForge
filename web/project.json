{
  "name": "web",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "web/src",
  "projectType": "application",
  "tags": ["type:app", "scope:web"],
  "// targets": "to see all targets run: nx show project web --web",
  "targets": {
    "dev": {
      "executor": "nx:run-commands",
      "cache": false,
      "options": {
        "cwd": "{workspaceRoot}/web",
        "command": "../node_modules/.bin/vite",
        "color": true,
        "env": {
          "NODE_OPTIONS": "--max-http-header-size=131072"
        }
      }
    },
    "deploy": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "cwd": "{workspaceRoot}",
        "command": "npx firebase deploy --only hosting"
      }
    },
    "deploy-fresh": {
      "executor": "nx:run-commands",
      "cache": false,
      "options": {
        "cwd": "{workspaceRoot}",
        "command": "NX_DAEMON=false NX_ISOLATE_PLUGINS=false yarn nx run web:build --skip-nx-cache && npx firebase deploy --only hosting"
      }
    }
  }
}
