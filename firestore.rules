rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user owns the resource (path-based)
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Enforce bounded collection queries (rules are not filters).
    function isBoundedList(maxLimit) {
      return request.query.limit != null
        && request.query.limit > 0
        && request.query.limit <= maxLimit;
    }

    // All user-scoped collections under users/{userId}/
    match /users/{userId} {
      // Documents — server-maintained via Cloud Functions; client read-only.
      match /documents/{documentId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId) && isBoundedList(100);
        allow create, update, delete: if false;

        match /{nestedPath=**} {
          allow read, write: if false;
        }
      }

      // Quizzes — server-maintained via Cloud Functions; client read-only.
      match /quizzes/{quizId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId) && isBoundedList(50);
        allow create, update, delete: if false;

        match /{nestedPath=**} {
          allow read, write: if false;
        }
      }

      // Directories subcollection — user-managed folders.
      match /directories/{directoryId} {
        function isValidDirectory() {
          return request.resource.data.name is string &&
                 request.resource.data.name.size() > 0 &&
                 request.resource.data.name.size() <= 100 &&
                 request.resource.data.level >= 0 &&
                 request.resource.data.level <= 10;
        }

        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidDirectory();
        allow update: if isOwner(userId) && isValidDirectory();
        allow delete: if isOwner(userId);

        // Materialized directory listing index — server-maintained, client read-only.
        match /items/{itemId} {
          allow read: if isOwner(userId);
          allow write: if false;
        }

        // Directory chat — server-maintained via Cloud Functions; callable API only.
        match /chat/{threadId} {
          allow read, write: if false;

          match /messages/{messageId} {
            allow read, write: if false;
          }
        }

        match /{otherNested=**} {
          allow read, write: if false;
        }
      }

      // Rules — server-maintained via Cloud Functions; client read-only.
      match /rules/{ruleId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId) && isBoundedList(100);
        allow create, update, delete: if false;

        match /{nestedPath=**} {
          allow read, write: if false;
        }
      }

      // Flashcard sets — server-maintained via Cloud Functions; client read-only.
      match /flashcardSets/{flashcardSetId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId) && isBoundedList(50);
        allow create, update, delete: if false;

        match /{nestedPath=**} {
          allow read, write: if false;
        }
      }

      // Slide decks — server-maintained via Cloud Functions; client read-only.
      match /slideDecks/{slideDeckId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId) && isBoundedList(50);
        allow create, update, delete: if false;

        match /{nestedPath=**} {
          allow read, write: if false;
        }
      }

      // Diagram quizzes — server-maintained via Cloud Functions; client read-only.
      match /diagramQuizzes/{diagramQuizId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId) && isBoundedList(50);
        allow create, update, delete: if false;

        match /{nestedPath=**} {
          allow read, write: if false;
        }
      }

      // Sequence quizzes — server-maintained via Cloud Functions; client read-only.
      match /sequenceQuizzes/{sequenceQuizId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId) && isBoundedList(50);
        allow create, update, delete: if false;

        match /{nestedPath=**} {
          allow read, write: if false;
        }
      }

      // Subject worlds — server-maintained via Cloud Functions; client read-only.
      match /subjectWorlds/{subjectWorldId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId) && isBoundedList(50);
        allow create, update, delete: if false;

        // Progress snapshots — owner get only; writes via Cloud Functions.
        match /progress/{progressId} {
          allow get: if isOwner(userId) && progressId == userId;
          allow list: if false;
          allow create, update, delete: if false;
        }

        match /{otherNested=**} {
          allow read, write: if false;
        }
      }

      // Generation jobs — server-maintained via Cloud Functions.
      match /generationJobs/{jobId} {
        allow read, write: if false;
      }

      // Interaction tracking — server-maintained via Cloud Functions.
      match /interactionSessions/{sessionId} {
        allow read, write: if false;
      }

      match /interactionStats/{statId} {
        allow read, write: if false;
      }

      // Learning telemetry — server-maintained via Cloud Functions.
      match /learningEvents/{eventId} {
        allow read, write: if false;
      }

      match /quizAttempts/{attemptId} {
        allow read, write: if false;
      }

      match /quizStats/{statId} {
        allow read, write: if false;
      }

      match /questionStats/{statId} {
        allow read, write: if false;
      }

      match /knowledgeStats/{statId} {
        allow read, write: if false;
      }

      // API rate limits — server-maintained via Cloud Functions.
      match /apiRateLimits/{limitId} {
        allow read, write: if false;
      }

      // API keys are managed only via Cloud Functions.
      match /apiKeys/{keyId} {
        allow read, write: if false;
      }
    }
  }
}
