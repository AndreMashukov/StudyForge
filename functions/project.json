{
  "name": "functions",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "functions/src",
  "projectType": "application",
  "tags": ["type:app", "scope:backend"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/functions/lib/src/index.js"],
      "options": {
        "command": "node functions/esbuild.config.mjs"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p functions/tsconfig.json --noEmit"
      }
    },
    "build-with-deps": {
      "executor": "nx:run-commands",
      "options": {
        "command": "nx run shared-types:build && nx run functions:build"
      },
      "dependsOn": ["shared-types:build"]
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": [
          "functions/src/**/*.{ts,tsx}",
          "libs/backend/**/*.{ts,tsx}"
        ]
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx firebase emulators:start"
      },
      "dependsOn": ["build"]
    },
    "deploy": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node_modules/.bin/firebase deploy --only functions --project study-forge-202604"
      },
      "dependsOn": ["build"]
    },
    "deploy-selected": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx scripts/deploy-selected-functions.ts --functions={args.functions} --firebase-project={args.firebaseProject} --print-only={args.printOnly}"
      },
      "dependsOn": ["build"]
    },
    "shell": {
      "executor": "nx:run-commands",
      "options": {
        "command": "yarn shell",
        "cwd": "functions"
      }
    }
  },
  "implicitDependencies": [
    "shared-types",
    "core",
    "llm",
    "generation",
    "documents",
    "directories",
    "artifacts"
  ]
}
