{
  "name": "ui",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/ui/src",
  "projectType": "library",
  "tags": ["type:lib", "scope:ui"],
  "targets": {
    "storybook": {
      "executor": "nx:run-commands",
      "cache": false,
      "options": {
        "cwd": "{workspaceRoot}",
        "command": "storybook dev -c libs/ui/.storybook -p 4401"
      }
    },
    "build-storybook": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{workspaceRoot}",
        "command": "storybook build -c libs/ui/.storybook -o dist/storybook/ui"
      }
    }
  }
}
