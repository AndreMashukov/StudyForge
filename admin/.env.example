# Admin app — copy to admin/.env.local for local development

# Firebase client config (browser login only)
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# Use Firebase emulators (align ports with web/functions: Auth 9099, Firestore 8080)
NEXT_PUBLIC_USE_FIREBASE_EMULATOR=true
NEXT_AUTH_EMULATOR_HOST=localhost:9099
NEXT_FIRESTORE_EMULATOR_HOST=localhost:8080

# Firebase Admin SDK (server only — never use NEXT_PUBLIC_ prefix)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=your-service-account@your-project-id.iam.gserviceaccount.com
# Escape newlines as \n when setting in Vercel
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Emulator mode (no service account required when emulators are running)
# FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
# FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
# GCLOUD_PROJECT=your-project-id

# Session
ADMIN_SESSION_COOKIE_NAME=admin_session

# Required to encrypt admin-managed OpenRouter credentials before storing them.
# Use a long random value and keep it server-side only.
LLM_SETTINGS_ENCRYPTION_KEY=replace-with-a-long-random-secret

# Admin access requires Firebase Auth custom claim: {"role": "admin"}


